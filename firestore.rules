rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().data.active == true;
    }

    function adminUser() {
      return activeUser() && currentUserDoc().data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if adminUser();
    }

    match /transactions/{transactionId} {
      allow read, create, update, delete: if activeUser();
    }

    match /employees/{employeeId} {
      allow read: if activeUser();
      allow create, update: if adminUser();
      allow delete: if false;
    }

    match /deleted_transactions/{deletedTransactionId} {
      allow create: if activeUser();
      allow read: if adminUser();
      allow update, delete: if false;
    }

    match /tuccarlar/{merchantId} {
      allow read, create, update, delete: if activeUser();
    }

    match /satislar/{saleId} {
      allow read, create, update, delete: if activeUser();
    }

    match /tahsilatlar/{paymentId} {
      allow read, create, update, delete: if activeUser();
    }

    match /giderler/{expenseId} {
      allow read, create, update, delete: if activeUser();
    }

    match /tarim_tarlalar/{fieldId} {
      allow read, create, update, delete: if activeUser();
    }

    match /tarim_isciler/{workerId} {
      allow read, create, update: if activeUser();
      allow delete: if false;
    }

    match /tarim_isci_gunleri/{workId} {
      allow read, create, update, delete: if activeUser();
    }

    match /tarim_isci_odemeleri/{paymentId} {
      allow read, create, update, delete: if activeUser();
    }

    match /kayisi_cinsleri/{varietyId} {
      allow read, create, update, delete: if activeUser();
    }
  }
}
